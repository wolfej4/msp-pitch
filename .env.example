# Branding (shows in UI and on PDF proposals)
COMPANY_NAME=Wolfden IT
COMPANY_TAGLINE=Managed IT Services
COMPANY_EMAIL=hello@wolfe.house
COMPANY_PHONE=
COMPANY_WEBSITE=https://wolfe.house

# ---- LLM provider ----
# Set to "anthropic" or "ollama"
LLM_PROVIDER=ollama

# If using Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# If using Ollama (recommend a model that supports tool/function calling
# if you ever extend this; for plain chat any decent model works)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# ---- SMTP (only needed if you want to email proposals from inside the app) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=proposals@wolfe.house
SMTP_TLS=true
